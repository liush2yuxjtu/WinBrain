# Required for Kimi Code-backed chat and skill drafting through Claude Agent SDK.
# Primary is attempted first. The secondary credential is attempted only after a real SDK error,
# timeout, or quota failure. If every configured credential fails, the request fails explicitly;
# no deterministic chat or Skill content is generated.
KIMI_API_KEY_PRIMARY=your_primary_kimi_api_key_here
KIMI_API_KEY_FALLBACK=your_fallback_kimi_api_key_here
KIMI_BASE_URL=https://api.kimi.com/coding/
KIMI_THINKING_TOKENS=32768
CLAUDE_CODE_AUTO_COMPACT_WINDOW=262144
AGENT_SDK_ATTEMPT_TIMEOUT_MS=600000

# Deprecated compatibility aliases remain supported during migration:
# KIMI_API_KEY, ANTHROPIC_API_KEY_PRIMARY, ANTHROPIC_API_KEY_FALLBACK,
# ANTHROPIC_AUTH_TOKEN_PRIMARY, ANTHROPIC_AUTH_TOKEN_FALLBACK,
# ANTHROPIC_API_KEY, and ANTHROPIC_AUTH_TOKEN.
# Do not set ANTHROPIC_MODEL: Kimi routes K2.7 Code when Thinking mode is enabled.

# Skill Store backend: filesystem or database. This is an explicit selection;
# database failures never switch to filesystem automatically.
SKILL_STORE_DRIVER=filesystem

# Filesystem backend configuration
SKILL_STUDIO_STORAGE_DIR=data/generated-skills

# PostgreSQL application database: companies, experts, data-source settings, and database Skill Store
DATABASE_URL=postgresql://winbrain:winbrain@127.0.0.1:5432/winbrain?schema=public

# Encrypts customer database passwords with AES-256-GCM.
# Generate with: node -e "console.log(require('node:crypto').randomBytes(32).toString('base64'))"
DATA_SOURCE_ENCRYPTION_KEY=replace_with_base64_encoded_32_byte_key

# Local development only: permits 127.0.0.1/private-network customer database targets.
# Production defaults to blocking private, loopback, link-local, and reserved targets.
ALLOW_PRIVATE_DATA_SOURCE_HOSTS=true

# Optional production allowlist. Comma-separated exact domains or domain suffixes.
# Example: oceanbase.example.com,db.customer-a.example
DATA_SOURCE_ALLOWED_HOST_SUFFIXES=

# Required for Auth.js / NextAuth email+password auth
# Generate a secret with: openssl rand -base64 32
AUTH_SECRET=replace_with_32_byte_random_secret
NEXTAUTH_URL=http://localhost:3000

# Single-admin credentials for the initial password auth implementation
AUTH_USER_EMAIL=admin@example.com
AUTH_USER_NAME=Studio Admin
AUTH_USER_ROLE=admin
# Generate with: npm run auth:hash-password -- "replace_this_password"
AUTH_USER_PASSWORD_HASH=replace_with_bcrypt_hash
