# Required for Claude Agent SDK-backed chat and skill drafting
# Primary is attempted first. Fallback is attempted after an SDK error, timeout, or quota failure.
ANTHROPIC_API_KEY_PRIMARY=your_primary_api_key_here
ANTHROPIC_API_KEY_FALLBACK=your_fallback_api_key_here
ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic
ANTHROPIC_MODEL=MiniMax-M3
AGENT_SDK_ATTEMPT_TIMEOUT_MS=60000

# Legacy single-key variables are still supported for local compatibility.
ANTHROPIC_API_KEY=your_primary_api_key_here
ANTHROPIC_AUTH_TOKEN=your_primary_api_key_here

# Optional local storage path for generated skills
SKILL_STUDIO_STORAGE_DIR=data/generated-skills

# Required for Auth.js / NextAuth email+password auth
# Generate a secret with: openssl rand -base64 32
AUTH_SECRET=replace_with_32_byte_random_secret
NEXTAUTH_URL=http://localhost:3000

# Single-admin credentials for the initial password auth implementation
AUTH_USER_EMAIL=admin@example.com
AUTH_USER_NAME=Studio Admin
AUTH_USER_ROLE=admin
# Generate with: npm run auth:hash-password -- "replace_this_password"
AUTH_USER_PASSWORD_HASH=replace_with_bcrypt_hash
