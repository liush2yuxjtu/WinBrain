{
  "name": "business-skill-studio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "prisma generate",
    "dev": "next dev",
    "prebuild": "prisma generate",
    "build": "next build",
    "start": "next start",
    "pretypecheck": "prisma generate",
    "typecheck": "tsc --noEmit",
    "auth:hash-password": "node scripts/hash-password.mjs",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "pretest:unit": "prisma generate",
    "test:unit": "node --import tsx --test tests/filesystem-skill-repository.test.ts tests/skill-store-validation.test.ts tests/data-source-security.test.ts tests/data-source-crypto.test.ts tests/agent-sdk-profiler.test.ts",
    "pretest:integration": "prisma generate",
    "test:integration": "node --import tsx --test --test-concurrency=1 tests/prisma-skill-repository.integration.test.ts tests/company-settings.integration.test.ts tests/customer-database.integration.test.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.206",
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "bcryptjs": "^2.4.3",
    "effect": "^3.0.0",
    "mysql2": "^3.14.0",
    "next": "^15.0.0",
    "next-auth": "^5.0.0-beta.29",
    "pg": "^8.16.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.15.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "dotenv": "^17.0.0",
    "prisma": "^7.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.0.0"
  }
}
