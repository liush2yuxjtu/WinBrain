# Copy this file to .env.uat. Never commit .env.uat.

# Isolated PostgreSQL application database
UAT_POSTGRES_DB=winbrain_uat
UAT_POSTGRES_USER=winbrain_uat
UAT_POSTGRES_PASSWORD=replace_with_a_long_random_password
UAT_POSTGRES_PORT=55432

# Isolated MySQL/OceanBase-compatible customer fixture
UAT_MYSQL_ROOT_PASSWORD=replace_with_a_long_random_root_password
UAT_MYSQL_DATABASE=uat_dws
UAT_MYSQL_READONLY_USER=winbrain_uat_readonly
UAT_MYSQL_READONLY_PASSWORD=replace_with_a_long_random_readonly_password
UAT_MYSQL_PORT=53307

# Application runtime
SKILL_STORE_DRIVER=database
DATABASE_URL=postgresql://winbrain_uat:replace_with_a_long_random_password@127.0.0.1:55432/winbrain_uat?schema=public
ALLOW_PRIVATE_DATA_SOURCE_HOSTS=true
DATA_SOURCE_ENCRYPTION_KEY=replace_with_base64_encoded_32_byte_key

# Authentication for a UAT application instance
AUTH_SECRET=replace_with_32_byte_random_secret
NEXTAUTH_URL=http://localhost:3000
AUTH_USER_EMAIL=uat-admin@example.com
AUTH_USER_NAME=UAT Admin
AUTH_USER_ROLE=admin
AUTH_USER_PASSWORD_HASH=replace_with_bcrypt_hash

# Kimi must be injected privately. Do not paste a real key into this file or Git.
KIMI_API_KEY_PRIMARY=
KIMI_API_KEY_FALLBACK=
KIMI_BASE_URL=https://api.kimi.com/coding/
KIMI_THINKING_TOKENS=32768
CLAUDE_CODE_AUTO_COMPACT_WINDOW=262144
AGENT_SDK_ATTEMPT_TIMEOUT_MS=600000
